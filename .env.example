DATABASE_URL=postgresql://user:password@host/db?sslmode=require
AUTH_SECRET=change-me-to-a-random-32-char-string
ADMIN_SEED_USERNAME=admin
ADMIN_SEED_PASSWORD=change-me
PUBLIC_BUSINESS_SLUG=picard-barber
# Optional: runtime TZ fallback (parseo explícito en código usa America/Santiago)
TZ=America/Santiago
# Vercel Blob (galería de fotos)
BLOB_READ_WRITE_TOKEN=vercel_blob_...
BLOB_STORE_ID=store_...
BLOB_WEBHOOK_PUBLIC_KEY=public_key_...