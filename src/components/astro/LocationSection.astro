---
interface Props {
  address: string;
  mapsUrl?: string | null;
}

const { address, mapsUrl } = Astro.props;
---

<section id="ubicacion" class="mt-20">
  <div class="mb-10 text-center">
    <h2 class="font-display text-3xl tracking-tight md:text-4xl">
      <span class="text-gradient-cyber">Ubicación</span>
    </h2>
    <p class="mt-2 text-muted">Encuéntranos aquí</p>
  </div>
  <div class="card card-hover mx-auto max-w-2xl text-center">
    <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full border border-accent/30 bg-accent/10">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path
          d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"
          stroke="#00F5D4"
          stroke-width="1.5"
          fill="none"></path>
        <circle cx="12" cy="9" r="2.5" stroke="#00F5D4" stroke-width="1.5"></circle>
      </svg>
    </div>
    <p class="text-lg">{address}</p>
    {
      mapsUrl && (
        <a
          href={mapsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary mt-6 inline-flex"
        >
          Ver en mapa
        </a>
      )
    }
  </div>
</section>
