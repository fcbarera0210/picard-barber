---
import BarberIcon from './BarberIcon.astro';

interface Props {
  address: string;
  mapsUrl?: string | null;
}

const { address, mapsUrl } = Astro.props;
---

<section id="ubicacion" class="mt-20">
  <div class="mb-8 border-b border-white/5 pb-4">
    <p class="font-mono text-xs uppercase tracking-widest text-accent">// Dónde encontrarnos</p>
    <h2 class="font-heading mt-1 text-3xl font-bold uppercase italic md:text-4xl">
      <span class="text-gradient-cyber">Ubicación</span>
    </h2>
  </div>
  <div class="card card-hover mx-auto max-w-2xl text-center">
    <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded border border-accent/30 bg-accent/10">
      <BarberIcon icon="scissors" tone="accent" size="lg" label="Ubicación" />
    </div>
    <p class="text-lg">{address}</p>
    {
      mapsUrl && (
        <a
          href={mapsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary mt-6 inline-flex"
        >
          Ver en mapa
        </a>
      )
    }
  </div>
</section>
