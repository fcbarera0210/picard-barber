---
import BarberIcon from './BarberIcon.astro';
import { resolveMapEmbedUrl, toGoogleMapsLink } from '../../lib/maps';

interface ScheduleDay {
  day: string;
  ranges: string[];
}

interface Props {
  schedule: ScheduleDay[];
  address?: string | null;
  mapsUrl?: string | null;
}

const { schedule, address, mapsUrl } = Astro.props;

const hasSchedule = schedule.length > 0;
const hasAddress = Boolean(address?.trim());
const showSection = hasSchedule || hasAddress;

const embedUrl = await resolveMapEmbedUrl(mapsUrl, address);
const externalMapLink = toGoogleMapsLink(mapsUrl, address);
const showMap = Boolean(embedUrl);
---

{
  showSection && (
    <section id="horarios" class="mt-20">
      <div class="mb-8 border-b border-white/5 pb-4">
        <p class="font-mono text-xs uppercase tracking-widest text-accent">// Visítanos</p>
        <h2 class="font-heading mt-1 text-3xl font-bold uppercase italic md:text-4xl">
          <span class="text-gradient-cyber">Horarios</span>
          <span class="text-white"> y </span>
          <span class="text-gradient-cyber">ubicación</span>
        </h2>
      </div>

      <div
        class:list={[
          'visit-section-grid grid gap-8 lg:grid-cols-2',
          hasSchedule && hasAddress ? 'visit-section-grid--paired' : 'lg:items-start',
        ]}
      >
        {hasSchedule && (
          <div class="visit-section-col order-2 flex flex-col lg:order-1">
            <h3 class="mb-4 font-heading text-lg font-bold uppercase tracking-wide text-accent">
              Horarios de atención
            </h3>
            <div class="card visit-schedule-card grid gap-4 sm:grid-cols-2">
              {schedule.map((s) => (
                <div>
                  <p class="font-heading text-base font-bold uppercase text-accent">{s.day}</p>
                  <ul class="mt-2 space-y-1">
                    {s.ranges.map((r) => (
                      <li class="font-mono text-sm text-muted">{r}</li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </div>
        )}

        {hasAddress && (
          <div
            class:list={[
              'visit-section-col order-1 flex flex-col',
              hasSchedule ? 'lg:order-2' : 'lg:col-span-2 lg:mx-auto lg:max-w-2xl lg:w-full',
            ]}
          >
            <h3 class="mb-4 font-heading text-lg font-bold uppercase tracking-wide text-accent">
              Dónde estamos
            </h3>
            <div class="card visit-location-card card-hover flex flex-col gap-4">
              <div class="visit-location-header flex flex-col gap-2 lg:flex-row lg:items-start lg:justify-between lg:gap-x-4 lg:gap-y-2">
                <div class="flex items-start justify-between gap-3 lg:contents">
                  <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded border border-accent/30 bg-accent/10 lg:order-1">
                    <BarberIcon icon="scissors" tone="accent" size="md" label="Ubicación" />
                  </div>

                  {externalMapLink && (
                    <a
                      href={externalMapLink}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="visit-maps-link shrink-0 lg:order-3"
                    >
                      <svg
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        aria-hidden="true"
                        class="visit-maps-link-icon"
                      >
                        <path
                          d="M12 21s7-4.35 7-10a7 7 0 1 0-14 0c0 5.65 7 10 7 10Z"
                          stroke="currentColor"
                          stroke-width="1.75"
                          stroke-linejoin="round"
                        />
                        <circle cx="12" cy="11" r="2.5" stroke="currentColor" stroke-width="1.75" />
                      </svg>
                      <span>Google Maps</span>
                      <svg
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        aria-hidden="true"
                        class="visit-maps-link-external"
                      >
                        <path
                          d="M7 17L17 7M17 7H9M17 7V15"
                          stroke="currentColor"
                          stroke-width="1.75"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        />
                      </svg>
                    </a>
                  )}
                </div>

                <p class="visit-location-address text-base leading-relaxed whitespace-nowrap md:text-lg lg:order-2 lg:min-w-0 lg:flex-1 lg:whitespace-normal lg:pt-1.5">
                  {address}
                </p>
              </div>

              {showMap && embedUrl && (
                <div class="visit-map-frame rounded border border-white/10">
                  <iframe
                    src={embedUrl}
                    title={`Mapa: ${address}`}
                    referrerpolicy="no-referrer-when-downgrade"
                    allowfullscreen
                  />
                </div>
              )}
            </div>
          </div>
        )}
      </div>
    </section>
  )
}
