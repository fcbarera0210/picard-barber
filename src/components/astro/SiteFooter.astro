---
interface Props {
  businessName: string;
  address?: string | null;
  mapsUrl?: string | null;
  instagramUrl?: string | null;
  whatsappNumber?: string | null;
}

const { businessName, address, mapsUrl, instagramUrl, whatsappNumber } = Astro.props;

const whatsappHref = whatsappNumber
  ? `https://wa.me/${whatsappNumber.replace(/\D/g, '')}`
  : null;
---

<footer class="relative z-10 border-t border-white/5 bg-surface/80 py-12 backdrop-blur-sm">
  <div class="mx-auto max-w-7xl px-4 md:px-6">
    <div class="flex flex-col items-center gap-6 text-center sm:flex-row sm:justify-between sm:text-left">
      <div>
        <p class="font-heading text-xl font-bold uppercase italic tracking-tight">
          <span class="text-white">PICARD</span><span class="text-accent neon-text-acid">BARBER</span>
        </p>
        {address && <p class="mt-2 text-sm text-muted">{address}</p>}
      </div>
      <div class="flex flex-wrap items-center justify-center gap-4 text-sm">
        {
          mapsUrl && (
            <a href={mapsUrl} target="_blank" rel="noopener noreferrer" class="nav-link pb-1">
              Mapa
            </a>
          )
        }
        {
          instagramUrl && (
            <a href={instagramUrl} target="_blank" rel="noopener noreferrer" class="nav-link pb-1">
              Instagram
            </a>
          )
        }
        {
          whatsappHref && (
            <a href={whatsappHref} target="_blank" rel="noopener noreferrer" class="nav-link pb-1">
              WhatsApp
            </a>
          )
        }
        <a href="/reservar" class="btn-primary px-4 py-2 text-xs">Reservar</a>
      </div>
    </div>
    <p class="mt-8 text-center text-xs text-muted">
      &copy; {new Date().getFullYear()} {businessName}
    </p>
  </div>
</footer>
