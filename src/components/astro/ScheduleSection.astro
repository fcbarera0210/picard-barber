---
interface ScheduleDay {
  day: string;
  ranges: string[];
}

interface Props {
  schedule: ScheduleDay[];
}

const { schedule } = Astro.props;
---

{
  schedule.length > 0 && (
    <section id="horarios" class="mt-20">
      <div class="mb-8 border-b border-white/5 pb-4">
        <p class="font-mono text-xs uppercase tracking-widest text-accent">// Horarios del local</p>
        <h2 class="font-heading mt-1 text-3xl font-bold uppercase italic md:text-4xl">
          <span class="text-gradient-cyber">Horarios</span>
        </h2>
      </div>
      <div class="card grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {schedule.map((s) => (
          <div>
            <p class="font-heading text-lg font-bold uppercase text-accent">{s.day}</p>
            <ul class="mt-2 space-y-1">
              {s.ranges.map((r) => (
                <li class="font-mono text-sm text-muted">{r}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>
  )
}
