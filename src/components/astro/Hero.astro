---
interface Props {
  name: string;
  description: string;
}

const { description } = Astro.props;
---

<section class="relative overflow-hidden py-12 text-right md:py-20">
  <div
    class="pointer-events-none absolute -right-[15%] top-1/2 z-0 h-[min(90vw,520px)] w-[min(90vw,520px)] -translate-y-1/2 rounded-full border border-white/10 opacity-40"
    aria-hidden="true"
  ></div>
  <div
    class="pointer-events-none absolute -right-[20%] top-1/2 z-0 h-[min(100vw,600px)] w-[min(100vw,600px)] -translate-y-1/2 rounded-full border border-dashed border-accent/30 opacity-30"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 ml-auto max-w-3xl">
    <div class="space-y-6">
      <div class="space-y-2">
        <p class="font-mono text-xs uppercase tracking-[0.25em] text-accent">// Barbería premium & estilo</p>
        <h1 class="font-heading text-right text-5xl font-bold uppercase italic leading-[0.95] tracking-tight sm:text-6xl md:text-7xl lg:text-8xl">
          <span class="block text-white neon-text-acid sm:inline">Picard</span>
          <span class="text-gradient-cyber block sm:inline">Barber</span>
        </h1>
      </div>

      <p class="ml-auto max-w-xl text-right text-base text-muted md:text-lg">
        {description}
      </p>

      <div class="flex flex-wrap justify-end gap-4 pt-2">
        <a href="/reservar" class="btn-primary">Reservar ahora</a>
        <a href="#servicios" class="btn-secondary">Ver servicios</a>
      </div>

      <a
        href="#servicios"
        class="inline-flex flex-col items-end gap-0 pt-4 text-accent transition-colors hover:text-accent-hover"
        aria-label="Desplázate hacia abajo"
      >
        <svg width="16" height="10" viewBox="0 0 16 10" fill="none" aria-hidden="true">
          <path d="M1 1.5L8 8.5L15 1.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <svg width="16" height="10" viewBox="0 0 16 10" fill="none" class="-mt-1.5 text-accent/70" aria-hidden="true">
          <path d="M1 1.5L8 8.5L15 1.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <svg width="16" height="10" viewBox="0 0 16 10" fill="none" class="-mt-1.5 text-accent/40" aria-hidden="true">
          <path d="M1 1.5L8 8.5L15 1.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
  </div>
</section>
