---
interface Props {
  name: string;
  description: string;
}

const { description } = Astro.props;
---

<section class="relative overflow-hidden py-12 md:py-20">
  <div
    class="pointer-events-none absolute left-1/2 top-1/2 z-0 h-[min(90vw,520px)] w-[min(90vw,520px)] -translate-x-1/2 -translate-y-1/2 rounded-full border border-white/10 opacity-40"
    aria-hidden="true"
  ></div>
  <div
    class="pointer-events-none absolute left-1/2 top-1/2 z-0 h-[min(100vw,600px)] w-[min(100vw,600px)] -translate-x-1/2 -translate-y-1/2 rounded-full border border-dashed border-accent/30 opacity-30"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 grid items-center gap-12 xl:grid-cols-[1.15fr_0.85fr]">
    <div class="space-y-6">
      <div class="space-y-2">
        <p class="font-mono text-xs uppercase tracking-[0.25em] text-accent">// Barbería premium & estilo</p>
        <h1 class="font-heading text-5xl font-bold uppercase italic leading-[0.95] tracking-tight sm:text-6xl md:text-7xl lg:text-8xl">
          <span class="block text-white neon-text-acid sm:inline">Picard</span>
          <span class="text-gradient-cyber block sm:inline">Barber</span>
        </h1>
      </div>

      <p class="max-w-xl text-base text-muted md:text-lg">
        {description}
      </p>

      <div class="flex flex-wrap gap-4 pt-2">
        <a href="/reservar" class="btn-primary">Reservar ahora</a>
        <a href="#servicios" class="btn-secondary">Ver servicios</a>
      </div>

      <div class="flex items-center gap-3 pt-4 font-mono text-xs text-muted">
        <span>// Navegación</span>
        <span class="text-accent">▶</span>
        <span class="text-accent/70">▶</span>
        <span class="text-accent/40">▶</span>
      </div>
    </div>
  </div>
</section>
