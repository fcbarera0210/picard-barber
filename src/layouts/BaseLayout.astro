---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { MobileNav } from '../components/react/MobileNav';
import { TechnoSynth } from '../components/react/TechnoSynth';
import { ParallaxBackground } from '../components/react/ParallaxBackground';
import SiteFooter from '../components/astro/SiteFooter.astro';
import { getActiveBusiness } from '../lib/business';

interface Props {
  title?: string;
  description?: string;
}

const biz = await getActiveBusiness();
const businessName = biz?.name ?? 'Picard Barber';

const {
  title = businessName,
  description = biz?.description ?? 'Barbería premium. Reserva tu hora online.',
} = Astro.props;
---

<!doctype html>
<html lang="es" class="min-h-dvh">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Montserrat:ital,wght@0,700;0,800;1,700;1,800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="flex min-h-dvh flex-col overflow-x-hidden bg-bg text-ink">
    <ParallaxBackground client:load />
    <header class="sticky top-0 z-50 border-b border-white/5 bg-bg/90 backdrop-blur-md">
      <nav class="mx-auto flex h-20 max-w-7xl items-center justify-between px-4 md:px-6">
        <a href="/" class="font-heading text-lg font-bold uppercase italic tracking-widest md:text-xl">
          <span class="text-white">PICARD</span><span class="text-accent neon-text-acid">BARBER</span>
        </a>
        <div class="hidden items-center gap-6 lg:flex">
          <a href="/#servicios" class="nav-link pb-1">Servicios</a>
          <a href="/#horarios" class="nav-link pb-1">Horarios</a>
          <a href="/#ubicacion" class="nav-link pb-1">Ubicación</a>
          <a href="/mis-reservas" class="nav-link pb-1">Mis reservas</a>
          <a href="/reservar" class="btn-primary px-5 py-2.5">Reservar</a>
        </div>
        <div class="flex items-center gap-2">
          <TechnoSynth client:load transition:persist="techno-audio" variant="header" />
          <MobileNav client:load />
        </div>
      </nav>
    </header>
    <main class="relative z-10 mx-auto w-full max-w-7xl flex-1 px-4 py-6 md:px-6 md:py-8" transition:animate="fade">
      <slot />
    </main>
    <SiteFooter
      businessName={businessName}
      address={biz?.address}
      mapsUrl={biz?.mapsUrl}
      instagramUrl={biz?.instagramUrl}
      whatsappNumber={biz?.whatsappNumber}
    />
  </body>
</html>
