---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { MobileNav } from '../components/react/MobileNav';
import { TechnoSynth } from '../components/react/TechnoSynth';
import AmbientBackground from '../components/astro/AmbientBackground.astro';
import SiteFooter from '../components/astro/SiteFooter.astro';
import { getActiveBusiness } from '../lib/business';

interface Props {
  title?: string;
  description?: string;
}

const biz = await getActiveBusiness();
const businessName = biz?.name ?? 'Picard Barber';

const {
  title = businessName,
  description = biz?.description ?? 'Barbería premium. Reserva tu hora online.',
} = Astro.props;
---

<!doctype html>
<html lang="es" class="min-h-dvh">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Space+Grotesk:wght@500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="flex min-h-dvh flex-col bg-bg text-ink">
    <AmbientBackground />
    <header class="sticky top-0 z-50 border-b border-white/5 bg-bg/80 backdrop-blur-md">
      <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4">
        <a href="/" class="font-display text-xl font-bold tracking-tight">
          <span class="text-accent neon-text-cyan">PICARD</span>
          <span class="text-white"> BARBER</span>
        </a>
        <div class="hidden items-center gap-8 text-sm font-medium lg:flex">
          <a href="/#servicios" class="nav-link pb-1">Servicios</a>
          <a href="/#horarios" class="nav-link pb-1">Horarios</a>
          <a href="/#ubicacion" class="nav-link pb-1">Ubicación</a>
          <a href="/mis-reservas" class="nav-link pb-1">Mis reservas</a>
          <a href="/reservar" class="btn-primary px-5 py-2.5 text-sm">Reservar</a>
        </div>
        <div class="flex items-center gap-2">
          <TechnoSynth client:load transition:persist="techno-audio" variant="header" />
          <MobileNav client:load />
        </div>
      </nav>
    </header>
    <main class="relative z-10 mx-auto w-full max-w-7xl flex-1 px-4 py-8" transition:animate="fade">
      <slot />
    </main>
    <SiteFooter
      businessName={businessName}
      address={biz?.address}
      mapsUrl={biz?.mapsUrl}
      instagramUrl={biz?.instagramUrl}
      whatsappNumber={biz?.whatsappNumber}
    />
  </body>
</html>
