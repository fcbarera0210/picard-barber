---
import BaseLayout from '../layouts/BaseLayout.astro';
import { BookingFlow } from '../components/react/BookingFlow';
import { getActiveBusiness } from '../lib/business';

export const prerender = false;

const biz = await getActiveBusiness();
const serviceId = Astro.url.searchParams.get('serviceId') ?? undefined;
---

<BaseLayout title={`Reservar — ${biz?.name ?? 'Picard Barber'}`}>
  <div class="mb-10 text-center">
    <h1 class="font-display text-4xl tracking-tight md:text-5xl">
      <span class="text-gradient-cyber">Reserva tu hora</span>
    </h1>
    <p class="mt-2 text-muted">Elige servicio, fecha y confirma en minutos</p>
  </div>
  <BookingFlow client:load initialServiceId={serviceId} />
</BaseLayout>
