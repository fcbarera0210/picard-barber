---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/astro/Hero.astro';
import ServicesGrid from '../components/astro/ServicesGrid.astro';
import ScheduleSection from '../components/astro/ScheduleSection.astro';
import LocationSection from '../components/astro/LocationSection.astro';
import CTABanner from '../components/astro/CTABanner.astro';
import { ScrollReveal } from '../components/react/ScrollReveal';
import { getActiveBusiness } from '../lib/business';
import { DAYS_ORDER, DAY_LABELS } from '../lib/schedule';
import { db } from '../lib/db';
import { services, availabilityBlocks } from '../lib/db/schema';
import { eq, asc } from 'drizzle-orm';

export const prerender = false;

const biz = await getActiveBusiness();
const serviceList = biz
  ? await db
      .select()
      .from(services)
      .where(eq(services.businessId, biz.id))
      .orderBy(asc(services.sortOrder))
  : [];

const activeServices = serviceList.filter((s) => s.active);

const avail = biz
  ? await db
      .select()
      .from(availabilityBlocks)
      .where(eq(availabilityBlocks.businessId, biz.id))
  : [];

const scheduleByDay = DAYS_ORDER.map((day) => ({
  day: DAY_LABELS[day],
  ranges: avail
    .filter((a) => a.dayOfWeek === day && a.active)
    .map((a) => `${a.startTime} – ${a.endTime}`),
})).filter((s) => s.ranges.length > 0);
---

<BaseLayout>
  <Hero
    name={biz?.name ?? 'Picard Barber'}
    description={biz?.description ?? 'Cortes clásicos y modernos. Reserva tu hora en segundos.'}
  />

  <ServicesGrid services={activeServices} />

  <ScrollReveal client:load>
    <ScheduleSection schedule={scheduleByDay} />
  </ScrollReveal>

  {
    biz?.address && (
      <ScrollReveal client:load>
        <LocationSection address={biz.address} mapsUrl={biz.mapsUrl} />
      </ScrollReveal>
    )
  }

  <ScrollReveal client:load>
    <CTABanner />
  </ScrollReveal>
</BaseLayout>
