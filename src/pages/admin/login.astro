---
import '../../styles/global.css';
import { AdminLoginForm } from '../../components/react/AdminLoginForm';

export const prerender = false;

const authError = Astro.url.searchParams.get('error');
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>Admin — Picard Barber</title>
  </head>
  <body class="flex min-h-screen items-center justify-center bg-bg px-4">
    <AdminLoginForm client:load authError={authError} />
  </body>
</html>
