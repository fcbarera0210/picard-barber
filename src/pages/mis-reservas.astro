---
import BaseLayout from '../layouts/BaseLayout.astro';
import { MyBookingsLookup } from '../components/react/MyBookingsLookup';
import { getActiveBusiness } from '../lib/business';

export const prerender = false;

const biz = await getActiveBusiness();
---

<BaseLayout title={`Mis reservas — ${biz?.name ?? 'Picard Barber'}`}>
  <div class="mb-8 text-center md:text-left">
    <p class="font-mono text-xs uppercase tracking-widest text-accent">// Consulta por email</p>
    <h1 class="font-heading mt-1 text-4xl font-bold uppercase italic tracking-tight md:text-5xl">
      <span class="text-gradient-cyber">Mis reservas</span>
    </h1>
    <p class="mt-2 text-muted">Consulta tus citas con tu email</p>
  </div>
  <MyBookingsLookup client:load />
</BaseLayout>
